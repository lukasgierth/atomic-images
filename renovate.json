{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "assignees": ["lukasgierth"],
  "prHourlyLimit": 0,
  "prConcurrentLimit": 0,
  "packageRules": [
    {
      "description": "match all and enable all update types",
      "matchUpdateTypes": ["major", "minor", "patch", "pin", "digest"],
      "automerge": false,
      "addLabels": ["renovate", "{{updateType}}"],
      "enabled": true
    }
  ]
}
