[Unit]
Description=Set up nixbld group and add all users to it
ConditionPathExists=!/etc/setup-nixbld-group
After=multi-user.target

[Service]
Type=oneshot
ExecStart=/usr/bin/bash -c "getent group nixbld &> /dev/null || groupadd -r nixbld; for user in $(getent passwd | grep 'home' | awk -F: '{print $1}'); do usermod -aG nixbld $user; done"
ExecStart=/usr/bin/touch /etc/setup-nixbld-group
ExecStart=/usr/bin/systemctl restart nix-daemon.service

[Install]
WantedBy=multi-user.target
